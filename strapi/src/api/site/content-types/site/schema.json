{
  "kind": "collectionType",
  "collectionName": "sites",
  "info": {
    "singularName": "site",
    "pluralName": "sites",
    "displayName": "站点"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "code": {
      "type": "uid"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "description": "网站主 Logo（浅色背景使用）"
    },
    "logoDark": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "description": "网站深色 Logo（深色背景使用，可选）"
    },
    "favicon": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "description": "网站 favicon 图标"
    },
    "appleTouchIcon": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "description": "iOS 主屏图标（可选）"
    },
    "icp": {
      "type": "string"
    },
    "copyright": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "i18nEnabled": {
      "type": "boolean",
      "default": false
    }
  }
}
