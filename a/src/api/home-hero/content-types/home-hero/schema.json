{
  "kind": "collectionType",
  "collectionName": "home_heros",
  "info": {
    "singularName": "home-hero",
    "pluralName": "home-heros",
    "displayName": "首页封面"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "site": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::site.site",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "subtitle": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "video": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["videos"]
    },
    "isTop": {
      "type": "boolean",
      "default": false
    },
    "marqueeText": {
      "type": "string"
    },
    "marqueeEnabled": {
      "type": "boolean",
      "default": false
    },
    "marqueeSpeed": {
      "type": "integer",
      "default": 28
    },
    "ctaLabel": {
      "type": "string"
    },
    "ctaHref": {
      "type": "string"
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    },
    "isActive": {
      "type": "boolean",
      "default": true
    }
  }
}

